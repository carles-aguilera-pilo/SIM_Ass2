knitr::opts_chunk$set(echo = TRUE)
rm(list=ls())
load('mobiles.RData')
summary(df)
str(df)
df$brand <- as.factor(df$brand)
df$company <- as.factor(df$company) # WE HAVE CONVERTED THAT ELEMENTS TO FACTORS, BECAUSE WE WANT TO OPERATE WITH FACTORS NOT WITH
hist(df$Price)
qqnorm(df$Price)
qqline(df$Price)
shapiro.test(df$Price) # P-VALUE = 2.2e-16.
var_out <- summary(df$Price); var_out
iqr <- var_out[5] - var_out[2]; iqr
# MILD OUTLAYERS.
mild <- which(df$Price <  var_out[2] - 1.5*iqr | df$Price > var_out[5] + 1.5*iqr); length(mild)
mild_outlayers <- c(var_out[2] - 1.5*iqr, var_out[5] + 1.5*iqr); mild_outlayers
# HERE WE HAVE THE MILD OUTLAYERS . LOWER AND UPPER THRESHOLD FOR MILD OUTLAYERS ---> [-26023.5 , 46012.5].
# SEVERE OUTLAYERS.
sev <- which(df$Price < var_out[2] - 3*iqr  |  df$Price >  var_out[5] + 3*iqr); length(sev)
severe_outlayers  <- c(var_out[2] - 3*iqr, var_out[5] + 3*iqr); severe_outlayers
# HERE WE HAVE THE SEVERE OUTLAYERS ---> [-53037 , 73026].
# SO, WE HAVE A TOTAL 33 SEVERE OUTLAYERS AND 29 MILD OUTLAYERS.
# THE ID'S OF THE OBSERVATIONS ARE:
df$id[c(sev, mild)] # hHERE WE HAVE ALL THE ID'S OF THE OURTLAYERS, EXTREME/SEVERE AND MILD.
# Look if this outlayers depend on the company.
prop.table(table(df$company)) # THE ONES THAT HAVE THE MOST ARE APPLE.
prop.table(table(df$company[c(sev,mild)])) # HERE WE HAVE THAT THE MOST ONE'S ARE APPLE AND SAMSUNG, SO YES IT CAN DEPEN OF THE COMPANY.
df <- df[df$Price < 200000,]
# FOR THE IMPUTATION METHOD WE'LL USE THE MICE FUNCTION, FIRST, LET'S SEE WHICH VALUES WE HAVE TO IMPUTE.
summary(df)
library(mice)
res.mice <- mice(df[,3:11])
df_imp <- complete(res.mice)
quantile(df$Ratings, na.rm = TRUE); quantile(df_imp$Ratings)
quantile(df$RAM, na.rm = TRUE); quantile(df_imp$RAM)
quantile(df$ROM, na.rm = TRUE); quantile(df_imp$ROM)
quantile(df$Mobile_Size, na.rm = TRUE); quantile(df_imp$Mobile_Size)
quantile(df$Selfi_Cam, na.rm = TRUE); quantile(df_imp$Selfi_Cam)
# WE CAN SEE THAT THE DISTRIBUTION IS ALMOST THE SAME, THE VALUES CHANGE BUT CHANGE AS LITLE BIT, SO, THAT'S NOT PERFECT, BUT WE HAVE TO RETAIN ALL VALUES.
df[,3:11] <- df_imp
summary(df)
# WE'RE GOING TO DETECT MULTIVARIATE OUTLAYERS --> NUMERIC ONLY AND THE ONE'S THAT ARE GOOD FOR THE TEST OF THE MULTIVARIATE OUTLAYERS.
table(df$Primary_Cam)
res.mout <- Moutlier(df[,c(4,6,7,9:11)], quantile = 0.99)
# WE'RE GOING TO DETECT MULTIVARIATE OUTLAYERS --> NUMERIC ONLY AND THE ONE'S THAT ARE GOOD FOR THE TEST OF THE MULTIVARIATE OUTLAYERS.
table(df$Primary_Cam)
res.mout <- Moutlier(df[,c(4,6,7,9:11)], quantile = 0.99)
library(chemometrics)
res.mout <- Moutlier(df[,c(4,6,7,9:11)], quantile = 0.99)
# WE'RE GOING TO DETECT MULTIVARIATE OUTLAYERS --> NUMERIC ONLY AND THE ONE'S THAT ARE GOOD FOR THE TEST OF THE MULTIVARIATE OUTLAYERS.
table(df$Primary_Cam)
library(chemometrics)
res.mout <- Moutlier(df[,c(4,6,7,9:11)], quantile = 0.99)
plot(res.mout$md, res.mout$rd)
abline(h = res.mout$cutoff, col = 'red')
abline(v = res.mout$cutoff, col = 'red')
df$mvout <- 0
indx <- which(res.mout$md > res.mout$cutoff & res.mout$rd > res.mout$cutoff); indx; length(indx)
df$mvout[indx] <- 1
df$mvout <- factor(df$mvout, labels = c("Mvout-N", "Mvout-Y"))
# LET'S PROFILE , TAKE INTO ACCOUNT TO CHOOSE THE CORRECT NUMEBR TO PROFILE IF WE REDUCE THE DIMENSION OF SELECTED TABLE.
library(FactoMineR)
res.c <- catdes(df[,c(3:12)], num.var = 10)
res.c$test.chi2
res.c$quanti.var # WE CAN SEE HERE THAT THE PRICE HAS A LOT OF ASSOCIATION. AND ALSO THE MOBILE SIZE, THE REST ALSO HAVE BUT TOO LOW BECAUSE WE HAVE VALUES 0.0X SO THAT TO CLOSE FROM 0.
res.c$category
# HERE WE CAN SEE THAT IS THE APPLE COMPANMY THE ONE THAT HAS A HUGE PRESENCE IN THE MULTIVARIATE OUTLAYERS, ALSO ONEPLUS AND ALCATEL.
res.c$quanti
# THE ONE'S THAT ARE MULTIVARIATE OUTLAYERS ARE THOSE ONE'S THAT HAVE A MEAN PRICE TO MUCH HIGH REPSECT TO THE MEAN IN POPULATION AND ALSO MORE MOBILE SIZE AND MORE SELFI-CAM, BUT, SPECIALLY THE HUGE DIFERENCE IS ON THE PRICE.
# we have to do for the target price a numeric condes profiling.
res.con <- condes(df[3:11], num.var = 9)
res.con$quanti # HERE WE HAVE THAT THE VARIABLES THAT HAS MORE CORRELATION ARE RATINGS, ROM AND BATTERY POWER.
res.con$category # THE FACTOR, QUALITATIVE VARIABLE THAT HAS MORE ASSOCIATION WITH THE PRICE TARGET VALUE IS THE COMPANY
res.con$quali # SO FINALLY WE CAN SEE THAT APPLE PRICE IS 73847 HIGHER RESPECT TO THE MEAN, AND SNBEXIAN IS 12046 BELOW THE MEAN RESPECT TO THE MEAN ON POPULATION.
# SO THE APPLE IS ONE OF THE MOST (THE FIRST ONE ) THAT IS THE EXPENSIVE ONE, WHEREAS THE SNEXIAN IS ONE OF THE LOWEST ONE'S, SO ONE OF THE CHEAPEST ONE'S.
# NOW WE'RE GOING TO PROFILE THE QUALITATVIE / FACTOR / CATEGORICAL TARGET VARIABLE, COMPANY
res.cat <- catdes(df[,c(3:11)], num.var = 1)
res.cat$quanti.var # the one's that are moree associated with the target company are ratings, price, battery power and ROM
res.cat$quanti
# HERE WE CAN SEE THAT APPLE THE PRICE IS TO MUCH ABOVE THAN THE OVERALL MEAN , SO THAT MEANS THAT APPLE IS THE ONE WHO IS   MORE EXPENSIVE.
# IN THE OTHER HAND WE CAN SEE THAT ALCATEL THE RAM, AND THE PRIMARY CAM PIXELS AND SELFI_CAM PIXELS ARE BELOW THE OVERALL MEAN. ALSO SNEXIAN WITH THE PRICE, BATTERY AND ROM ARE SO BELOW RESPECT THE OVERALL MEAN, THAT MAYBE JUSTIFIES THAT IS THE CHEAPEST ONE.
boxplot(df$Price~df$company)
?fligner.test
fligner.test(df$Price~df$company, data = df)
sort(tapply(df$Price, df$company, sd))
fligner.test(df$Price~df$company, data= df)
hist(df$Price)
qqnorm(df$Price)
qqline(df$Price)
?kruskal.test
kruskal.test(df$Price~df$company, data= df)
llidx <- which(df$company == 'Apple'); llidx
apple <- df[llidx,]
?t.test
?wilcox.test
t.test(apple$Price, conf.level= 0.99)
wilcox.test(apple$Price, conf.int = TRUE, conf.level = 0.99)
idx1 <- which(df$company == 'Xiaomi'); idx1
idx2 <- which(df$company != 'Xiaomi'); idx2
xiaomi <- df[idx1,]
rest <- df[idx2,]
?wilcox.test
wilcox.test(xiaomi$Price, rest$Price, alternative = "less", conf.level = 0.99)
wilcox.test(xiaomi$Price, rest$Price, alternative = "less", conf.level = 0.99)
wilcox.test(xiaomi$Price, rest$Price, alternative = "greater", conf.level = 0.99)
# FIRST WE COMPUTE THE STANDARD DEVIATION
idx <- which(df$company == 'Xiaomi')
xiaomi <- df[idx,]
sd(xiaomi$Price)
??varTest
# IN THAT CASE IF WE ASSUME NORMALITY, WE WILL USE PARAMETRIC TEST, SO IN THAT CASE, ASSUMING PARAMETRIC ASSUMPTIONS.
# WE'LL USE FOR THAT CASE varTest.
library(EnvStats)
varTest(xiaomi$Price,alternative = "greater", conf.level = 0.99)
varTest(xiaomi$Price,alternative = "greater", conf.level = 0.99, sigma.squared = 25000^2)
varTest(xiaomi$Price,alternative = "less", conf.level = 0.99, sigma.squared = 25000^2)
# CONFIDENCE INTERVAL FOR THE POPULATION PROPORTION APPLE DEVICES.
idx <- which(df$company == 'Apple')
apple <- df[idx,]
?prop.test
prop.test(apple$Price, conf.level = 0.99)
