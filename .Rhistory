res.c$test.chi2
res.c$quanti.var # WE CAN SEE HERE THAT THE PRICE HAS A LOT OF ASSOCIATION. AND ALSO THE MOBILE SIZE, THE REST ALSO HAVE BUT TOO LOW BECAUSE WE HAVE VALUES 0.0X SO THAT TO CLOSE FROM 0.
res.c$category
# HERE WE CAN SEE THAT IS THE APPLE COMPANMY THE ONE THAT HAS A HUGE PRESENCE IN THE MULTIVARIATE OUTLAYERS, ALSO ONEPLUS AND ALCATEL.
res.c$quanti
# THE ONE'S THAT ARE MULTIVARIATE OUTLAYERS ARE THOSE ONE'S THAT HAVE A MEAN PRICE TO MUCH HIGH REPSECT TO THE MEAN IN POPULATION AND ALSO MORE MOBILE SIZE AND MORE SELFI-CAM, BUT, SPECIALLY THE HUGE DIFERENCE IS ON THE PRICE.
# we have to do for the target price a numeric condes profiling.
res.con <- condes(df[3:11], num.var = 9)
res.con$quanti # HERE WE HAVE THAT THE VARIABLES THAT HAS MORE CORRELATION ARE RATINGS, ROM AND BATTERY POWER.
res.con$category # THE FACTOR, QUALITATIVE VARIABLE THAT HAS MORE ASSOCIATION WITH THE PRICE TARGET VALUE IS THE COMPANY
res.con$quali # SO FINALLY WE CAN SEE THAT APPLE PRICE IS 73847 HIGHER RESPECT TO THE MEAN, AND SNBEXIAN IS 12046 BELOW THE MEAN RESPECT TO THE MEAN ON POPULATION.
# SO THE APPLE IS ONE OF THE MOST (THE FIRST ONE ) THAT IS THE EXPENSIVE ONE, WHEREAS THE SNEXIAN IS ONE OF THE LOWEST ONE'S, SO ONE OF THE CHEAPEST ONE'S.
# NOW WE'RE GOING TO PROFILE THE QUALITATVIE / FACTOR / CATEGORICAL TARGET VARIABLE, COMPANY
res.cat <- catdes(df[,c(3:11)], num.var = 1)
res.cat$quanti.var # the one's that are moree associated with the target company are ratings, price, battery power and ROM
res.cat$quanti
# HERE WE CAN SEE THAT APPLE THE PRICE IS TO MUCH ABOVE THAN THE OVERALL MEAN , SO THAT MEANS THAT APPLE IS THE ONE WHO IS   MORE EXPENSIVE.
# IN THE OTHER HAND WE CAN SEE THAT ALCATEL THE RAM, AND THE PRIMARY CAM PIXELS AND SELFI_CAM PIXELS ARE BELOW THE OVERALL MEAN. ALSO SNEXIAN WITH THE PRICE, BATTERY AND ROM ARE SO BELOW RESPECT THE OVERALL MEAN, THAT MAYBE JUSTIFIES THAT IS THE CHEAPEST ONE.
